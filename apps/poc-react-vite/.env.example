# Frontend environment (local development)
# Copy this file to .env.local and adjust values for your machine.

# API Configuration
# Backend deve estar rodando em http://localhost:8080
# OBS: NÃO adicione /api ao final - o backend usa rotas diretas (/auth/login, /perfil, etc.)
VITE_API_BASE_URL=http://localhost:8080
VITE_API_URL=http://localhost:8080/api

# Optional: JWT token to use when there is no authenticated session token in state.
# Use only for development / testing; in production, tokens should come from login.
VITE_JWT_OVERRIDE=


